# ============================================================
#  Week 2 — Customer Churn Predictor
#  .gitignore — Om Sanjaysingh Bais
# ============================================================


# ------------------------------------------------------------
# 🔐  SECRETS — NEVER commit these
# ------------------------------------------------------------
.env
.env.*
*.pem
*.key
secrets/
credentials/


# ------------------------------------------------------------
# 🐍  Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST


# ------------------------------------------------------------
# 📦  Virtual Environments
# ------------------------------------------------------------
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/
.python-version


# ------------------------------------------------------------
# 📓  Jupyter Notebooks
# ------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py


# ------------------------------------------------------------
# 🤖  ML Models & Large Artifacts
#     Commit small demo models (<10MB) — gitignore heavy ones
# ------------------------------------------------------------
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
models/*.onnx

# Keep this line if you WANT to commit your demo model:
# !models/churn_model_demo.pkl


# ------------------------------------------------------------
# 📊  Data Files
#     Raw/processed data should NOT be in Git
#     Use a README note or DVC for large datasets
# ------------------------------------------------------------
data/raw/
data/processed/
*.csv
*.parquet
*.feather
*.h5
*.hdf5

# Allow the sample data placeholder
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep


# ------------------------------------------------------------
# 📝  Logs & Reports (generated at runtime)
# ------------------------------------------------------------
logs/
*.log
reports/figures/


# ------------------------------------------------------------
# 🐳  Docker
# ------------------------------------------------------------
.docker/


# ------------------------------------------------------------
# ⚡  FastAPI / Uvicorn
# ------------------------------------------------------------
*.pid


# ------------------------------------------------------------
# 🧪  Testing & Coverage
# ------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/
test-results/


# ------------------------------------------------------------
# 🔧  IDE & Editor Files
# ------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml
*.iws

# Vim / Neovim
*.swp
*.swo
*~

# Sublime Text
*.sublime-project
*.sublime-workspace

# Spyder
.spyderproject.cfg
.spyproject/

# Rope
.ropeproject/


# ------------------------------------------------------------
# 💻  OS Files
# ------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~


# ------------------------------------------------------------
# 📈  MLflow / Experiment Tracking (if added later)
# ------------------------------------------------------------
mlruns/
mlartifacts/


# ------------------------------------------------------------
# 📦  Node (if you add a frontend later)
# ------------------------------------------------------------
node_modules/
npm-debug.log*


# ------------------------------------------------------------
# 🌐  Render / Deployment
# ------------------------------------------------------------
.render/


# ============================================================
#  What IS committed (for clarity):
#  ✅ src/          — all Python source files
#  ✅ api/          — FastAPI app
#  ✅ notebooks/    — .ipynb files (outputs cleared before push)
#  ✅ tests/        — all test files
#  ✅ requirements.txt
#  ✅ README.md
#  ✅ Dockerfile    — if you add Docker
#  ✅ .gitignore    — this file
#  ✅ data/.gitkeep — empty placeholder so folder exists in Git
# ============================================================