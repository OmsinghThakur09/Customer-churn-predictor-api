# ============================================================
#  Week 2 — Customer Churn Predictor
#  .gitignore — Om Sanjaysingh Bais
# ============================================================


# ------------------------------------------------------------
# 🔐  SECRETS — NEVER commit these
# ------------------------------------------------------------
.env
.env.*
*.pem
*.key
secrets/
credentials/


# ------------------------------------------------------------
# 🐍  Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST


# ------------------------------------------------------------
# 📦  Virtual Environments
# ------------------------------------------------------------
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/
.python-version


# ------------------------------------------------------------
# 📓  Jupyter Notebooks
# ------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py


# ------------------------------------------------------------
# 🤖  ML Models & Artifacts — COMMIT these, they're small & needed for deploy
# ------------------------------------------------------------
# (no ignore rules — churn_model.pkl, preprocessor.pkl, shap_explainer.pkl,
#  model_metadata.json, and feature_names.csv are all tracked and required
#  for the live API to work on Render)


# ------------------------------------------------------------
# 📊  Data Files — raw/processed CSVs stay local, too large / not needed live
# ------------------------------------------------------------
data/raw/*.csv
data/processed/*.npy
data/processed/*.png

# Keep folders in git without their contents
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep

# Explicitly un-ignore the one CSV your API needs at runtime
!data/processed/feature_names.csv


# ------------------------------------------------------------
# 📝  Logs & Reports (generated at runtime)
# ------------------------------------------------------------
logs/
*.log
reports/figures/


# ------------------------------------------------------------
# 🐳  Docker
# ------------------------------------------------------------
.docker/


# ------------------------------------------------------------
# ⚡  FastAPI / Uvicorn
# ------------------------------------------------------------
*.pid


# ------------------------------------------------------------
# 🧪  Testing & Coverage
# ------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/
test-results/


# ------------------------------------------------------------
# 🔧  IDE & Editor Files
# ------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml
*.iws

# Vim / Neovim
*.swp
*.swo
*~

# Sublime Text
*.sublime-project
*.sublime-workspace

# Spyder
.spyderproject.cfg
.spyproject/

# Rope
.ropeproject/


# ------------------------------------------------------------
# 💻  OS Files
# ------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~


# ------------------------------------------------------------
# 📈  MLflow / Experiment Tracking (if added later)
# ------------------------------------------------------------
mlruns/
mlartifacts/


# ------------------------------------------------------------
# 📦  Node (if you add a frontend later)
# ------------------------------------------------------------
node_modules/
npm-debug.log*


# ------------------------------------------------------------
# 🌐  Render / Deployment
# ------------------------------------------------------------
.render/


# ============================================================
#  What IS committed (for clarity):
#  ✅ src/          — all Python source files
#  ✅ api/          — FastAPI app
#  ✅ notebooks/    — .ipynb files (outputs cleared before push)
#  ✅ tests/        — all test files
#  ✅ requirements.txt
#  ✅ README.md
#  ✅ Dockerfile    — if you add Docker
#  ✅ .gitignore    — this file
#  ✅ data/.gitkeep — empty placeholder so folder exists in Git
# ============================================================